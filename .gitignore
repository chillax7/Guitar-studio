venv/
__pycache__/
*.pyc
.DS_Store
.claude/

# User audio data — large binaries, not source. Back these up separately
# (e.g. an external drive or cloud storage sized for media), not in git.
input/
separated/
output/
# Per-user saved state (mixes, rig presets, playlists, practice history) —
# same reasoning as the audio dirs above: personal data, not source, and
# committing it would leak one user's library/practice habits into the repo.
GuitarStudio/projects/
GuitarStudio/models/*
# ...except a couple of small MIT-licensed starter NAM captures (from
# TONE3000's neural-amp-modeler-wasm repo) bundled so Play Along is
# testable out of the box. Anything else dropped into models/nam/ or
# models/ir/ (your own captures/IRs) stays untracked.
!GuitarStudio/models/nam
!GuitarStudio/models/nam/deluxe.nam
!GuitarStudio/models/nam/ac10.nam
# Same deal for one clearly-synthetic test/starter cab IR (not a real
# cabinet capture — see its filename) so the Cab IR picker has something
# to load out of the box too.
!GuitarStudio/models/ir
!GuitarStudio/models/ir/synthetic-test-cab.wav

# Build artifacts
*.app/
GuitarStudio/server.log
